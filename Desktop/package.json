{
  "name": "restopos",
  "version": "1.0.0",
  "description": "RestoPOS Offline Billing Software",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prebuild": "node build.js",
    "dist": "npm run prebuild && electron-builder --mac"
  },
  "build": {
    "appId": "com.mstechhive.msbilling",
    "productName": "msbilling",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "package.json",
      "frontend/**/*",
      "backend/**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    }
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.2.3",
    "electron-builder": "^24.9.1"
  }
}
